			"name": "Paste Level String",
			"type": "bool",
			"default": true
		},
		"level-copy-type": {
			"name": "Level Copy Type",
			"type": "string",
			"default": "Encoded",
			"one-of": ["Encoded", "Decoded"]
		}
	},
	"links": {
